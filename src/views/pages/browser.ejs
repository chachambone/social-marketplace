<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../components/head', { 
        title: title, 
        description: description 
    }) %>
</head>

<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    
    
        <%- include('../components/navbar', { user: user, currentPath: currentPath }) %>


    <!-- Dynamic Component Container for Marketplace App -->
    <div id="marketplace-app-container" class="min-h-screen">
        <%- include('dynamic-component-container', { 
            containerClass: 'animate-fadeIn',
            loadingText: 'Loading marketplace...'
        }) %>
    </div>
    
    <!-- Component configuration using component-loader -->
    <%- include('component-loader', { 
        components: [
            { 
                fileName: 'marketplaceApp.js', 
                componentName: 'marketplaceApp',
                customName: 'marketplace-app',
                props: {},
                events: {
                    'login-success': 'onLoginSuccess',
                    'logout': 'onLogout',
                    'theme-changed': 'onThemeChanged'
                }
            }
        ],
        basePath: '/',
        debug: process.env.NODE_ENV === 'development',
        autoLoad: true,
        containerId: 'marketplace-app-container',
        containerClass: 'animate-fadeIn',
        loadingText: 'Loading marketplace...',
        customHandlers: {
            onLoginSuccess: (e) => {
                console.log('Login success in browser page:', e.detail);
                // Force page reload to update server-side session
                setTimeout(() => {
                    window.location.href = '/';
                }, 500);
            },
            onLogout: (e) => {
                console.log('Logout in browser page');
                // Force page reload to update server-side session
                setTimeout(() => {
                    window.location.href = '/';
                }, 500);
            },
            onThemeChanged: (e) => {
                console.log('Theme changed:', e.detail);
                if (e.detail && e.detail.isDarkMode) {
                    document.body.classList.add('dark-mode');
                } else {
                    document.body.classList.remove('dark-mode');
                }
            }
        }
    }) %>
    
   
</body>
</html>