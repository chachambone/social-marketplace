<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    
    <!-- Import map for Lit -->
    <script type="importmap">
        {
            "imports": {
                "lit": "https://cdn.jsdelivr.net/npm/lit@3.2.1/index.js",
                "lit/": "https://cdn.jsdelivr.net/npm/lit@3.2.1/",
                "lit/decorators.js": "https://cdn.jsdelivr.net/npm/lit@3.2.1/decorators.js"
            }
        }
    </script>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        
        .animate-fadeIn {
            animation: fadeIn 0.5s ease-out;
        }
        
        .animate-slideInRight {
            animation: slideInRight 0.5s ease-out;
        }
        
        .chat-container {
            height: calc(100vh - 200px);
        }
        
        /* Custom scrollbar */
        .messages-container::-webkit-scrollbar {
            width: 6px;
        }
        
        .messages-container::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 3px;
        }
        
        .messages-container::-webkit-scrollbar-thumb {
            background: #F3A712;
            border-radius: 3px;
        }
        
        .messages-container::-webkit-scrollbar-thumb:hover {
            background: #F97316;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- Include Navbar -->
    <%- include('../components/navbar', { 
        user: user,
        currentPath: currentPath || '/seller/chats'
    }) %>
    
    <div class="max-w-7xl mx-auto px-4 py-8 mt-16">
        <div class="animate-fadeIn">
            <!-- Header -->
            <div class="bg-gradient-to-r from-[#F3A712] to-[#F97316] rounded-2xl p-6 mb-8 text-white shadow-lg">
                <div class="flex items-center gap-3">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                    </svg>
                    <div>
                        <h1 class="text-2xl font-bold">Seller Chat Center</h1>
                        <p class="text-white/90 text-sm">Manage conversations with buyers and close deals</p>
                    </div>
                </div>
            </div>
            
            <!-- Chat Container -->
            <div id="seller-chat-container" class="animate-slideInRight">
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden chat-container">
                    <div class="flex h-full">
                        <!-- Items List Sidebar -->
                        <div class="w-1/3 border-r border-gray-200 flex flex-col">
                            <div class="p-4 border-b border-gray-200 bg-gray-50">
                                <h2 class="font-semibold text-gray-900">Your Items with Active Chats</h2>
                                <p class="text-xs text-gray-500 mt-1">Click on an item to view conversations</p>
                            </div>
                            <div id="items-list" class="flex-1 overflow-y-auto">
                                <!-- Items will be loaded here -->
                                <div class="p-8 text-center text-gray-500">
                                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-[#F3A712]"></div>
                                    <p class="mt-2">Loading your items...</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Chat Area -->
                        <div class="w-2/3 flex flex-col">
                            <div id="chat-header" class="p-4 border-b border-gray-200 bg-gray-50">
                                <div class="text-center text-gray-500">
                                    <svg class="w-12 h-12 mx-auto mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                    </svg>
                                    <p class="font-medium">Select an item to start chatting</p>
                                    <p class="text-sm mt-1">Choose an item from the left sidebar</p>
                                </div>
                            </div>
                            <div id="chat-messages" class="flex-1 overflow-y-auto p-4 messages-container">
                                <!-- Messages will be loaded here -->
                            </div>
                            <div id="chat-input" class="p-4 border-t border-gray-200 bg-white">
                                <!-- Chat input will be shown when an item is selected -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Include Footer -->
    <%- include('../components/footer') %>
    
    <script>
        let currentItemId = null;
        let ws = null;
        let currentUser = <%- JSON.stringify(user) %>;
        
        // Load seller's items
        async function loadSellerItems() {
            try {
                const token = localStorage.getItem('accessToken');
                const response = await fetch(`/api/items/seller/${currentUser.id}/items`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.success && data.items) {
                        displayItemsList(data.items);
                    }
                }
            } catch (error) {
                console.error('Error loading items:', error);
                document.getElementById('items-list').innerHTML = `
                    <div class="p-8 text-center text-red-500">
                        <p>Failed to load items</p>
                        <button onclick="location.reload()" class="mt-2 text-sm text-[#F3A712]">Retry</button>
                    </div>
                `;
            }
        }
        
        // Display items list
        function displayItemsList(items) {
            const activeItems = items.filter(item => 
                item.status === 'active' || (item.bidCount > 0)
            );
            
            if (activeItems.length === 0) {
                document.getElementById('items-list').innerHTML = `
                    <div class="p-8 text-center text-gray-500">
                        <svg class="w-12 h-12 mx-auto mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                        <p class="font-medium">No active conversations</p>
                        <p class="text-sm mt-1">When buyers message you about your items, they'll appear here</p>
                    </div>
                `;
                return;
            }
            
            document.getElementById('items-list').innerHTML = activeItems.map(item => `
                <div 
                    onclick="selectItem('${item.id}', '${item.name}', '${item.image}')"
                    class="item-card p-4 border-b border-gray-100 hover:bg-gray-50 cursor-pointer transition-all"
                    data-item-id="${item.id}"
                >
                    <div class="flex gap-3">
                        <img src="${item.image}" alt="${item.name}" class="w-12 h-12 rounded-lg object-cover">
                        <div class="flex-1">
                            <h3 class="font-semibold text-gray-900 text-sm">${item.name}</h3>
                            <p class="text-xs text-gray-500 mt-1">Price: KSh ${item.price.toLocaleString()}</p>
                            ${item.bidCount > 0 ? `
                                <span class="inline-block mt-1 text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">
                                    ${item.bidCount} bid${item.bidCount !== 1 ? 's' : ''}
                                </span>
                            ` : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }
        
        // Select an item to chat about
        async function selectItem(itemId, itemName, itemImage) {
            if (currentItemId === itemId) return;
            
            currentItemId = itemId;
            
            // Update chat header
            document.getElementById('chat-header').innerHTML = `
                <div class="flex items-center gap-3">
                    <img src="${itemImage}" alt="${itemName}" class="w-10 h-10 rounded-lg object-cover">
                    <div class="flex-1">
                        <h3 class="font-semibold text-gray-900">${itemName}</h3>
                        <p class="text-xs text-gray-500">Active chat - Respond to buyers</p>
                    </div>
                    <button onclick="markAsSold()" class="bg-green-600 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-green-700 transition">
                        Mark as Sold
                    </button>
                </div>
            `;
            
            // Show chat input
            document.getElementById('chat-input').innerHTML = `
                <div class="flex gap-2">
                    <input 
                        type="text" 
                        id="messageInput"
                        placeholder="Type your message..."
                        class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#F3A712]"
                        onkeypress="if(event.key === 'Enter') sendMessage()"
                    />
                    <button onclick="sendMessage()" class="bg-[#F3A712] text-white px-4 py-2 rounded-lg hover:bg-[#F97316] transition">
                        Send
                    </button>
                </div>
            `;
            
            // Load chat history and connect WebSocket
            await loadChatHistory(itemId);
            connectWebSocket(itemId);
        }
        
        // Load chat history
        async function loadChatHistory(itemId) {
            try {
                const token = localStorage.getItem('accessToken');
                const response = await fetch(`/api/messages/item/${itemId}`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.success && data.messages) {
                        displayMessages(data.messages);
                    }
                }
            } catch (error) {
                console.error('Error loading chat history:', error);
            }
        }
        
        // Display messages
        function displayMessages(messages) {
            const container = document.getElementById('chat-messages');
            
            if (!messages || messages.length === 0) {
                container.innerHTML = `
                    <div class="text-center text-gray-500 py-12">
                        <svg class="w-12 h-12 mx-auto mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                        <p>No messages yet</p>
                        <p class="text-sm">Start a conversation with potential buyers</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = messages.map(msg => {
                const isOwner = msg.senderId === currentUser.id;
                const isBid = msg.type === 'bid';
                const isWinner = msg.type === 'winner_announcement';
                
                if (isWinner) {
                    return `
                        <div class="flex justify-center my-4">
                            <div class="bg-gradient-to-r from-yellow-400 to-orange-500 text-white px-4 py-2 rounded-lg text-sm">
                                ${msg.content}
                            </div>
                        </div>
                    `;
                }
                
                return `
                    <div class="flex ${isOwner ? 'justify-end' : 'justify-start'} mb-4">
                        <div class="max-w-[70%]">
                            <div class="text-xs text-gray-500 mb-1 ${isOwner ? 'text-right' : 'text-left'}">
                                ${msg.senderName} • ${new Date(msg.timestamp).toLocaleTimeString()}
                            </div>
                            <div class="${isOwner ? 'bg-[#F3A712] text-white' : 'bg-gray-100 text-gray-800'} rounded-lg p-3">
                                ${isBid ? `
                                    <div class="flex items-center gap-2">
                                        <span>💰</span>
                                        <span><strong>Bid placed:</strong> KSh ${msg.bidAmount?.toLocaleString()}</span>
                                    </div>
                                ` : `
                                    <p class="text-sm">${msg.content}</p>
                                `}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
            
            // Scroll to bottom
            container.scrollTop = container.scrollHeight;
        }
        
        // Connect WebSocket
        function connectWebSocket(itemId) {
            if (ws && ws.readyState === WebSocket.OPEN) {
                ws.close();
            }
            
            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/ws?itemId=${itemId}&userId=${currentUser.id}`;
            
            ws = new WebSocket(wsUrl);
            
            ws.onopen = () => {
                console.log('WebSocket connected for item:', itemId);
            };
            
            ws.onmessage = (event) => {
                const data = JSON.parse(event.data);
                if (data.type === 'history') {
                    displayMessages(data.messages);
                } else if (data.type !== 'system') {
                    // Append new message
                    const container = document.getElementById('chat-messages');
                    const isOwner = data.senderId === currentUser.id;
                    const isBid = data.type === 'bid';
                    
                    const messageHtml = `
                        <div class="flex ${isOwner ? 'justify-end' : 'justify-start'} mb-4">
                            <div class="max-w-[70%]">
                                <div class="text-xs text-gray-500 mb-1 ${isOwner ? 'text-right' : 'text-left'}">
                                    ${data.senderName} • ${new Date(data.timestamp).toLocaleTimeString()}
                                </div>
                                <div class="${isOwner ? 'bg-[#F3A712] text-white' : 'bg-gray-100 text-gray-800'} rounded-lg p-3">
                                    ${isBid ? `
                                        <div class="flex items-center gap-2">
                                            <span>💰</span>
                                            <span><strong>Bid placed:</strong> KSh ${data.bidAmount?.toLocaleString()}</span>
                                        </div>
                                    ` : `
                                        <p class="text-sm">${data.content}</p>
                                    `}
                                </div>
                            </div>
                        </div>
                    `;
                    
                    container.insertAdjacentHTML('beforeend', messageHtml);
                    container.scrollTop = container.scrollHeight;
                    
                    // Update bid count in sidebar
                    if (data.type === 'bid') {
                        updateBidCount(itemId);
                    }
                }
            };
            
            ws.onerror = (error) => {
                console.error('WebSocket error:', error);
            };
        }
        
        // Send message
        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input?.value.trim();
            
            if (!message || !ws || ws.readyState !== WebSocket.OPEN || !currentItemId) return;
            
            ws.send(JSON.stringify({
                type: 'message',
                itemId: currentItemId,
                senderId: currentUser.id,
                senderName: currentUser.username,
                content: message,
                timestamp: new Date().toISOString()
            }));
            
            input.value = '';
        }
        
        // Update bid count in sidebar
        function updateBidCount(itemId) {
            const itemCard = document.querySelector(`.item-card[data-item-id="${itemId}"]`);
            if (itemCard) {
                const currentCount = itemCard.querySelector('.bid-count');
                if (currentCount) {
                    const count = parseInt(currentCount.textContent) + 1;
                    currentCount.textContent = count;
                }
            }
        }
        
        // Mark item as sold
        async function markAsSold() {
            if (!currentItemId) return;
            
            const confirmed = confirm('Are you sure you want to mark this item as sold? This will end the auction.');
            if (!confirmed) return;
            
            try {
                const token = localStorage.getItem('accessToken');
                const response = await fetch(`/api/items/${currentItemId}/confirm-sale`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    }
                });
                
                if (response.ok) {
                    alert('Item marked as sold!');
                    window.location.reload();
                } else {
                    alert('Failed to mark item as sold');
                }
            } catch (error) {
                console.error('Error marking item as sold:', error);
                alert('An error occurred');
            }
        }
        
        // Initialize page
        loadSellerItems();
    </script>
</body>
</html>