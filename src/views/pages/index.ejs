                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        <span class="text-sm">Free listings</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                                            </path>
                                        </svg>
                                        <span class="text-sm">Buyer protection</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z">
                                            </path>
                                        </svg>
                                        <span class="text-sm">Live chat</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Stats Cards -->
                            <div class="grid grid-cols-1 gap-4">
                                <div
                                    class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/20 hover:bg-white/15 transition">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-white/80 text-sm">Active listings</p>
                                            <p class="text-white text-3xl font-bold" id="listings-count">Loading...</p>
                                        </div>
                                        <div class="bg-white/20 rounded-xl p-2.5 text-white">
                                            <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="mt-2 text-green-300 text-xs">Live items</div>
                                </div>
                                <div
                                    class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/20 hover:bg-white/15 transition">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-white/80 text-sm">Live chats today</p>
                                            <p class="text-white text-3xl font-bold">1,204</p>
                                        </div>
                                        <div class="bg-white/20 rounded-xl p-2.5 text-white">
                                            <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z">
                                                </path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="mt-2 text-green-300 text-xs">Real-time negotiations</div>
                                </div>
                                <div
                                    class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/20 hover:bg-white/15 transition">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-white/80 text-sm">Trusted sellers</p>
                                            <p class="text-white text-3xl font-bold">8,500</p>
                                        </div>
                                        <div class="bg-white/20 rounded-xl p-2.5 text-white">
                                            <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z">
                                                </path>
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="mt-2 text-green-300 text-xs">Verified community</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 h-24"
                        style="background: linear-gradient(to top, #f9fafb, transparent)"></div>
                </div>

                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
                    <!-- Categories Section -->
                    <div class="mb-16">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-900">Shop by category</h2>
                                <p class="text-gray-500 mt-1">Find exactly what you're looking for</p>
                            </div>
                            <a href="/browse"
                                class="text-[#F3A712] hover:text-[#F97316] font-medium flex items-center gap-1 text-sm">
                                View all
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        </div>
                        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                            <% const categories=[ { name: "Electronics" ,
                                icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                , count: "2,345 items" }, { name: "Photography" ,
                                icon: "M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                                , count: "1,234 items" }, { name: "Music" ,
                                icon: "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"
                                , count: "892 items" }, { name: "Furniture" ,
                                icon: "M3 12h18M3 6h18M5 6v12m14-12v12M7 6v12m10-12v12M9 6v12m6-12v12" ,
                                count: "1,567 items" }, { name: "Sports" ,
                                icon: "M12 18v-5a2 2 0 00-2-2H6a2 2 0 00-2 2v5m12-5a2 2 0 00-2-2h-4a2 2 0 00-2 2m4-5a4 4 0 10-8 0m8 0a4 4 0 10-8 0"
                                , count: "756 items" }, { name: "Fashion" ,
                                icon: "M20 7h-4.18A3 3 0 0016 5.18V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v1.18A3 3 0 008.18 7H4a2 2 0 00-2 2v3h20V9a2 2 0 00-2-2zm-6 12h-4v-3h4v3z"
                                , count: "2,101 items" } ]; %>
                                <% categories.forEach(cat=> { %>
                                    <a href="/browse?category=<%= encodeURIComponent(cat.name) %>"
                                        class="group bg-white rounded-xl p-5 text-center hover:shadow-lg transition-all border border-gray-100 hover:border-[#F3A712]">
                                        <div
                                            class="flex items-center justify-center mb-3 text-[#F3A712] group-hover:scale-110 transition-transform">
                                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="<%= cat.icon %>"></path>
                                            </svg>
                                        </div>
                                        <h3 class="font-medium text-gray-900 text-sm">
                                            <%= cat.name %>
                                        </h3>
                                        <p class="text-xs text-gray-400 mt-1">
                                            <%= cat.count %>
                                        </p>
                                    </a>
                                    <% }); %>
                        </div>
                    </div>

                    <!-- Trending Now Section with Dynamic ItemsGrid Component -->
                    <div class="mb-16">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <svg class="w-5 h-5 text-[#F3A712]" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                                    </svg>
                                    <h2 class="text-2xl font-bold text-gray-900">Trending now</h2>
                                </div>
                                <p class="text-gray-500 text-sm">Most popular items this week</p>
                            </div>
                            <a href="/browse"
                                class="text-[#F3A712] hover:text-[#F97316] font-medium flex items-center gap-1 text-sm">
                                View all
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        </div>

                        <!-- Dynamic Component Container for ItemsGrid -->
                        <div id="items-grid-container" class="animate-slideInRight">
                            <%- include('dynamic-component-container', { containerClass: 'animate-slideInRight' ,
                                loadingText: 'Loading items...' }) %>
                        </div>
                    </div>

                    <!-- How It Works -->
                    <div class="mb-16 rounded-2xl p-8 lg:p-10" style="background-color:#FEF9E6">
                        <div class="text-center mb-8">
                            <div class="flex items-center justify-center gap-2 mb-2">
                                <svg class="w-6 h-6 text-[#F3A712]" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z">
                                    </path>
                                </svg>
                                <h2 class="text-2xl font-bold text-gray-900">How it works</h2>
                            </div>
                            <p class="text-gray-500">Three simple steps to start buying and selling</p>
                        </div>
                        <div class="grid md:grid-cols-3 gap-8">
                            <div class="text-center">
                                <div class="w-14 h-14 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md"
                                    style="background-color:#F3A712">1</div>
                                <h3 class="font-semibold text-gray-900 mb-1">Create account</h3>
                                <p class="text-sm text-gray-500">Sign up in seconds, completely free</p>
                            </div>
                            <div class="text-center">
                                <div class="w-14 h-14 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md"
                                    style="background-color:#F3A712">2</div>
                                <h3 class="font-semibold text-gray-900 mb-1">List or browse</h3>
                                <p class="text-sm text-gray-500">Post items or find what you need</p>
                            </div>
                            <div class="text-center">
                                <div class="w-14 h-14 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md"
                                    style="background-color:#F3A712">3</div>
                                <h3 class="font-semibold text-gray-900 mb-1">Chat & deal</h3>
                                <p class="text-sm text-gray-500">Negotiate live, close instantly</p>
                            </div>
                        </div>
                    </div>

                    <!-- Testimonials -->
                    <div class="mb-16">
                        <div class="text-center mb-8">
                            <div class="flex items-center justify-center gap-2 mb-2">
                                <svg class="w-6 h-6 text-[#F3A712]" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z">
                                    </path>
                                </svg>
                                <h2 class="text-2xl font-bold text-gray-900">Trusted by the community</h2>
                            </div>
                            <p class="text-gray-500">What our users say about BidHive</p>
                        </div>
                        <div class="grid md:grid-cols-3 gap-6">
                            <% const testimonials=[ { name: "Sarah Johnson" , role: "Verified Seller" ,
                                text: "The chat feature helped me sell my camera within hours. Direct communication makes all the difference."
                                , rating: 5, avatar: "SJ" }, { name: "Michael Chen" , role: "Collector" ,
                                text: "Found rare vinyl records here that I've been searching for years. The platform is a hidden gem."
                                , rating: 5, avatar: "MC" }, { name: "Amina Wanjiku" , role: "Buyer" ,
                                text: "Safe, reliable, and the sellers are responsive. My go-to marketplace in Kenya." ,
                                rating: 5, avatar: "AW" } ]; %>
                                <% testimonials.forEach(t=> { %>
                                    <div
                                        class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition">
                                        <div class="flex items-center gap-0.5 mb-3">
                                            <% for(let i=0; i < t.rating; i++) { %>
                                                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor"
                                                    viewBox="0 0 20 20">
                                                    <path
                                                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                                                    </path>
                                                </svg>
                                                <% } %>
                                        </div>
                                        <p class="text-gray-600 text-sm leading-relaxed mb-4">"<%= t.text %>"</p>
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-full flex items-center justify-center text-white font-medium text-sm"
                                                style="background-color:#F3A712">
                                                <%= t.avatar %>
                                            </div>
                                            <div>
                                                <p class="font-medium text-gray-900 text-sm">
                                                    <%= t.name %>
                                                </p>
                                                <p class="text-xs text-gray-500">
                                                    <%= t.role %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <% }); %>
                        </div>
                    </div>

                    <!-- CTA Banner -->
                    <div class="rounded-2xl p-8 lg:p-10 text-center text-white"
                        style="background: linear-gradient(to right, #F3A712, #F97316)">
                        <div class="flex justify-center mb-3">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17.657 18.657A8 8 0 016.343 7.343S7 9 10 10c-2-1-4-1-6 0 1 1 2 2 4 3-1 1-2 2-3 4 2-1 4-2 6-3 1 1 2 2 4 3 0-2-1-4-2-6 2 0 4 1 5 2 0-2-1-4-2-6 1 1 2 2 3 4 0-2-1-4-2-6 1 1 2 2 3 4">
                                </path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold mb-2">Ready to start selling?</h2>
                        <p class="text-white/90 mb-5">Join thousands of sellers making money on BidHive</p>
                        <a href="/sell"
                            class="bg-white font-semibold px-6 py-2.5 rounded-lg hover:shadow-lg transition-all inline-flex items-center gap-2 text-sm"
                            style="color:#F3A712">
                            Start selling now
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7">
                                </path>
                            </svg>
                        </a>
                    </div>
                </div>
            </main>

            <!-- Include Footer Component -->
            <%- include('../components/footer') %>
        </div>

        <!-- Component configuration using component-loader -->
        <%- include('component-loader', { components: [ { fileName: 'ItemsGrid.js' , componentName: 'ItemsGrid' ,
            customName: 'items-grid' , props: { limit: 8, showFilters: false, showViewAll: true }, events:
            { 'item-click' : 'onItemClick' , 'add-to-cart' : 'onAddToCart' , 'items-loaded' : 'onItemsLoaded' } } ],
            basePath: '/components/' , debug: false, autoLoad: true, containerId: 'items-grid-container' ,
            containerClass: 'animate-slideInRight' , loadingText: 'Loading items...' , customHandlers: { onItemClick:
            (e)=> {
            console.log('Item clicked:', e.detail);
            if (e.detail && e.detail.id) {
            window.location.href = `/listing/${e.detail.id}`;
            }
            },
            onAddToCart: (e) => {
            console.log('Add to cart:', e.detail);
            // Show toast notification
            showToast('Item added to cart! 🛒', 'success');
            },
            onItemsLoaded: (e) => {
            console.log('Items loaded:', e.detail);
            // Update the stats counter
            if (e.detail && e.detail.count) {
            const listingsCountElem = document.getElementById('listings-count');
            if (listingsCountElem) {
            listingsCountElem.textContent = e.detail.count.toLocaleString();
            }
            }
            }
            }
            }) %>

            <script>
                // Toast notification system
                function showToast(message, type = 'success') {
                    // Remove existing toast
                    const existingToast = document.querySelector('.toast-notification');
                    if (existingToast) {
                        existingToast.remove();
                    }

                    // Create toast element
                    const toast = document.createElement('div');
                    toast.className = `toast-notification fixed bottom-4 right-4 z-50 bg-white rounded-xl shadow-2xl p-4 flex items-center gap-3 animate-slideUp`;

                    const icons = {
                        success: '✅',
                        error: '❌',
                        info: 'ℹ️',
                        warning: '⚠️'
                    };

                    const colors = {
                        success: 'border-l-4 border-green-500',
                        error: 'border-l-4 border-red-500',
                        info: 'border-l-4 border-blue-500',
                        warning: 'border-l-4 border-yellow-500'
                    };

                    toast.className += ` ${colors[type]}`;

                    toast.innerHTML = `
                <div class="text-2xl">${icons[type]}</div>
                <div class="flex-1">
                    <p class="text-gray-900 font-medium">${message}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="text-gray-400 hover:text-gray-600">
                    ✕
                </button>
            `;

                    document.body.appendChild(toast);

                    // Auto remove after 3 seconds
                    setTimeout(() => {
                        if (toast && toast.parentElement) {
                            toast.remove();
                        }
                    }, 3000);
                }

                // Set current year in footer
                document.getElementById('current-year').textContent = new Date().getFullYear();

                // Listen for dark mode changes
                window.addEventListener('darkmode-changed', (e) => {
                    if (e.detail.isDarkMode) {
                        document.body.classList.add('dark-mode');
                    } else {
                        document.body.classList.remove('dark-mode');
                    }
                });

                // Check initial dark mode
                const savedDarkMode = localStorage.getItem('bidhive_darkMode');
                if (savedDarkMode === 'true') {
                    document.body.classList.add('dark-mode');
                }

                // Smooth scroll for anchor links
                document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                    anchor.addEventListener('click', function (e) {
                        const href = this.getAttribute('href');
                        if (href !== '#') {
                            e.preventDefault();
                            const target = document.querySelector(href);
                            if (target) {
                                target.scrollIntoView({ behavior: 'smooth' });
                            }
                        }
                    });
