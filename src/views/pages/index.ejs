<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../components/head', { 
        title: title, 
        description: description 
    }) %>
</head>

<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- Navbar Component -->
    <%- include('../components/navbar', { user: user, currentPath: currentPath }) %>

        <div id="app" class="flex flex-col min-h-screen">
            <main class="flex-1 w-full">
                <!-- Hero Section -->
                <div class="relative overflow-hidden"
                    style="background: linear-gradient(135deg, #F3A712 0%, #F97316 60%, #FF6B35 100%)">
                    <div class="absolute inset-0 bg-black/5"></div>
                    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
                        <div class="grid lg:grid-cols-2 gap-12 items-center">

                            <!-- Left Content -->
                            <div class="text-white">
                                <div
                                    class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 mb-6 border border-white/20">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z">
                                        </path>
                                    </svg>
                                    <span class="text-sm font-medium">Trusted by 50,000+ Kenyans</span>
                                </div>
                                <h1 class="text-4xl lg:text-6xl font-black leading-tight mb-6 tracking-tight">
                                    Buy & Sell Anything
                                </h1>
                                <p class="text-xl text-white/95 mb-8 max-w-lg leading-relaxed">
                                    Kenya's fastest-growing marketplace where every listing has its own chat room.
                                    Negotiate live, close deals instantly.
                                </p>
                                <div class="flex flex-col sm:flex-row gap-4">
                                    <a href="/browse"
                                        class="bg-white text-[#F3A712] font-bold px-8 py-4 rounded-xl hover:shadow-2xl transition-all duration-300 text-lg flex items-center justify-center gap-2 group hover:-translate-y-0.5">
                                        Browse listings
                                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300"
                                            fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M9 5l7 7-7 7"></path>
                                        </svg>
                                    </a>
                                    <a href="/sell"
                                        class="backdrop-blur-md bg-white/20 text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/30 hover:scale-[1.02] transition-all duration-300 text-lg border border-white/30 shadow-lg hover:shadow-xl">
                                        Start selling
                                    </a>
                                </div>
