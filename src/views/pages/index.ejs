<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    
    <!-- Import map for Lit -->
    <script type="importmap">
        {
            "imports": {
                "lit": "https://cdn.jsdelivr.net/npm/lit@3.2.1/index.js",
                "lit/": "https://cdn.jsdelivr.net/npm/lit@3.2.1/",
                "lit/decorators.js": "https://cdn.jsdelivr.net/npm/lit@3.2.1/decorators.js",
                "lit-html": "https://cdn.jsdelivr.net/npm/lit-html@3.2.0/lit-html.js",
                "lit-html/": "https://cdn.jsdelivr.net/npm/lit-html@3.2.0/",
                "lit-element/lit-element.js": "https://cdn.jsdelivr.net/npm/lit-element@4.1.0/lit-element.js",
                "@lit/reactive-element": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/reactive-element.js",
                "@lit/reactive-element/": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/",
                "lucide-static/icons/": "https://cdn.jsdelivr.net/npm/lucide-static@0.371.0/icons/"
            }
        }
    </script>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .animate-spin {
            animation: spin 1s linear infinite;
        }
        
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0) scale(1) rotate(0deg); }
            50% { transform: translateY(-10px) scale(1.1) rotate(12deg); }
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slideDown { animation: slideDown 0.3s ease-out; }
        .animate-slideUp { animation: slideUp 0.3s ease-out; }
        .animate-bounce { animation: bounce 0.5s ease-in-out; }
        .animate-pulse { 
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; 
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .line-clamp-1 {
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        /* Dark mode styles */
        .dark-mode {
            background-color: #1a1a2e;
            color: #eee;
        }
        .dark-mode .bg-white {
            background-color: #16213e !important;
            color: #eee !important;
        }
        .dark-mode .bg-gray-50 {
            background-color: #0f3460 !important;
        }
        .dark-mode .bg-gray-100 {
            background-color: #1a2a3a !important;
        }
        .dark-mode .text-gray-900 {
            color: #eee !important;
        }
        .dark-mode .text-gray-600,
        .dark-mode .text-gray-500,
        .dark-mode .text-gray-400 {
            color: #aaa !important;
        }
        .dark-mode .border-gray-100,
        .dark-mode .border-gray-200 {
            border-color: #2a2a4a !important;
        }
        
        /* Hover effects */
        .hover-lift {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        }
        
        /* Hide scrollbar but keep functionality */
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- Navbar Component -->
     <%- include('navbar', { user: user, currentPath: currentPath }) %>
    
    <div id="app" class="flex flex-col min-h-screen">
        <main class="flex-1 w-full">
            <!-- Hero Section -->
            <div class="relative overflow-hidden" style="background: linear-gradient(135deg, #F3A712 0%, #F97316 60%, #FF6B35 100%)">
                <div class="absolute inset-0 bg-black/5"></div>
                <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
                    <div class="grid lg:grid-cols-2 gap-12 items-center">
                        
                        <!-- Left Content -->
                        <div class="text-white">
                            <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 mb-6 border border-white/20">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                                </svg>
                                <span class="text-sm font-medium">Trusted by 50,000+ Kenyans</span>
                            </div>
                            <h1 class="text-4xl lg:text-6xl font-black leading-tight mb-6 tracking-tight">
                                Buy & Sell Anything
                            </h1>
                            <p class="text-xl text-white/95 mb-8 max-w-lg leading-relaxed">
                                Kenya's fastest-growing marketplace where every listing has its own chat room. Negotiate live, close deals instantly.
                            </p>
                            <div class="flex flex-col sm:flex-row gap-4">
                                <a href="/browse" class="bg-white text-[#F3A712] font-bold px-8 py-4 rounded-xl hover:shadow-2xl transition-all text-lg flex items-center justify-center gap-2 group">
                                    Browse listings
                                    <svg class="w-4.5 h-4.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                                <a href="/sell" class="bg-white/20 backdrop-blur-sm text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/30 transition-all text-lg border border-white/30">
                                    Start selling
                                </a>
                            </div>
                            <div class="flex flex-wrap gap-6 mt-8 pt-6 border-t border-white/20">
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span class="text-sm">Free listings</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                    </svg>
                                    <span class="text-sm">Buyer protection</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                    </svg>
                                    <span class="text-sm">Live chat</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Stats Cards -->
                        <div class="grid grid-cols-1 gap-4">
                            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/20 hover:bg-white/15 transition">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-white/80 text-sm">Active listings</p>
                                        <p class="text-white text-3xl font-bold"><%= typeof listingsCount !== 'undefined' ? listingsCount.toLocaleString() : '12,345' %></p>
                                    </div>
                                    <div class="bg-white/20 rounded-xl p-2.5 text-white">
                                        <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="mt-2 text-green-300 text-xs">Live items</div>
                            </div>
                            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/20 hover:bg-white/15 transition">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-white/80 text-sm">Live chats today</p>
                                        <p class="text-white text-3xl font-bold">1,204</p>
                                    </div>
                                    <div class="bg-white/20 rounded-xl p-2.5 text-white">
                                        <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="mt-2 text-green-300 text-xs">Real-time negotiations</div>
                            </div>
                            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/20 hover:bg-white/15 transition">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-white/80 text-sm">Trusted sellers</p>
                                        <p class="text-white text-3xl font-bold">8,500</p>
                                    </div>
                                    <div class="bg-white/20 rounded-xl p-2.5 text-white">
                                        <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="mt-2 text-green-300 text-xs">Verified community</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to top, #f9fafb, transparent)"></div>
            </div>
            
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
                <!-- Categories Section -->
                <div class="mb-16">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h2 class="text-2xl font-bold text-gray-900">Shop by category</h2>
                            <p class="text-gray-500 mt-1">Find exactly what you're looking for</p>
                        </div>
                        <a href="/browse" class="text-[#F3A712] hover:text-[#F97316] font-medium flex items-center gap-1 text-sm">
                            View all
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                        <% const categories = [
                            { name: "Electronics", icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", count: "2,345 items" },
                            { name: "Photography", icon: "M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z", count: "1,234 items" },
                            { name: "Music", icon: "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3", count: "892 items" },
                            { name: "Furniture", icon: "M3 12h18M3 6h18M5 6v12m14-12v12M7 6v12m10-12v12M9 6v12m6-12v12", count: "1,567 items" },
                            { name: "Sports", icon: "M12 18v-5a2 2 0 00-2-2H6a2 2 0 00-2 2v5m12-5a2 2 0 00-2-2h-4a2 2 0 00-2 2m4-5a4 4 0 10-8 0m8 0a4 4 0 10-8 0", count: "756 items" },
                            { name: "Fashion", icon: "M20 7h-4.18A3 3 0 0016 5.18V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v1.18A3 3 0 008.18 7H4a2 2 0 00-2 2v3h20V9a2 2 0 00-2-2zm-6 12h-4v-3h4v3z", count: "2,101 items" }
                        ]; %>
                        <% categories.forEach(cat => { %>
                            <a href="/browse?category=<%= encodeURIComponent(cat.name) %>" class="group bg-white rounded-xl p-5 text-center hover:shadow-lg transition-all border border-gray-100 hover:border-[#F3A712]">
                                <div class="flex items-center justify-center mb-3 text-[#F3A712] group-hover:scale-110 transition-transform">
                                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= cat.icon %>"></path>
                                    </svg>
                                </div>
                                <h3 class="font-medium text-gray-900 text-sm"><%= cat.name %></h3>
                                <p class="text-xs text-gray-400 mt-1"><%= cat.count %></p>
                            </a>
                        <% }); %>
                    </div>
                </div>
                
                <!-- Trending Now Section -->
                <div class="mb-16">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <svg class="w-5 h-5 text-[#F3A712]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                                </svg>
                                <h2 class="text-2xl font-bold text-gray-900">Trending now</h2>
                            </div>
                            <p class="text-gray-500 text-sm">Most popular items this week</p>
                        </div>
                        <a href="/browse" class="text-[#F3A712] hover:text-[#F97316] font-medium flex items-center gap-1 text-sm">
                            View all
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    </div>
                    
                    <!-- Items Grid -->
                    <% if (typeof listings !== 'undefined' && listings.length > 0) { %>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                            <% listings.slice(0, 4).forEach(item => { %>
                                <div onclick="window.location.href='/listing/<%= item.id %>'" class="group bg-white rounded-xl overflow-hidden hover:shadow-xl transition-all cursor-pointer border border-gray-100 hover:-translate-y-1 duration-300">
                                    <div class="relative h-48 overflow-hidden bg-gray-100">
                                        <img src="<%= item.image || 'https://images.unsplash.com/photo-1472214103451-9374bd1c798e?w=400&h=300&fit=crop' %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                        <div class="absolute top-3 left-3">
                                            <span class="bg-white/95 text-gray-700 text-xs font-semibold px-2 py-1 rounded-lg"><%= item.category || 'Item' %></span>
                                        </div>
                                        <% if (!item.sold) { %>
                                            <div class="absolute top-3 right-3">
                                                <span class="text-white text-xs font-semibold px-2 py-1 rounded-md flex items-center gap-1 shadow-sm" style="background-color:#F3A712">
                                                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path>
                                                    </svg>
                                                    HOT
                                                </span>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="p-4">
                                        <h3 class="font-semibold text-gray-900 mb-1 line-clamp-1"><%= item.title %></h3>
                                        <p class="font-bold text-lg" style="color:#F3A712">KSh <%= Number(item.starting_price || item.price || 0).toLocaleString() %></p>
                                        <div class="flex items-center justify-between mt-2">
                                            <div class="flex items-center gap-1 text-xs text-gray-500">
                                                <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                </svg>
                                                <%= item.location || 'Kenya' %>
                                            </div>
                                            <div class="flex items-center gap-1 text-xs text-gray-500">
                                                <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                                <%= new Date(item.created_at).toLocaleDateString() %>
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-50">
                                            <div class="flex items-center gap-1.5">
                                                <div class="w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color:#F3A712">
                                                    <%= (item.seller_name || item.seller?.name || 'S')[0].toUpperCase() %>
                                                </div>
                                                <span class="text-xs text-gray-600"><%= item.seller_name || item.seller?.name || 'Seller' %></span>
                                            </div>
                                            <button class="text-xs px-3 py-1.5 rounded-lg font-semibold transition-all flex items-center gap-1" style="background-color:#FEF3D7; color:#F3A712">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                                </svg>
                                                Chat
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="py-20 text-center bg-white rounded-2xl border border-gray-100">
                            <div class="text-5xl mb-4">📦</div>
                            <h3 class="text-lg font-semibold text-gray-700 mb-2">No listings yet</h3>
                            <p class="text-gray-400 mb-6">Be the first to sell something on TradeHive!</p>
                            <a href="/sell" class="inline-block text-white font-semibold px-6 py-3 rounded-xl hover:opacity-90 transition" style="background-color:#F3A712">
                                List an Item 🐝
                            </a>
                        </div>
                    <% } %>
                </div>
                
                <!-- How It Works -->
                <div class="mb-16 rounded-2xl p-8 lg:p-10" style="background-color:#FEF9E6">
                    <div class="text-center mb-8">
                        <div class="flex items-center justify-center gap-2 mb-2">
                            <svg class="w-6 h-6 text-[#F3A712]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                            <h2 class="text-2xl font-bold text-gray-900">How it works</h2>
                        </div>
                        <p class="text-gray-500">Three simple steps to start buying and selling</p>
                    </div>
                    <div class="grid md:grid-cols-3 gap-8">
                        <div class="text-center">
                            <div class="w-14 h-14 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md" style="background-color:#F3A712">1</div>
                            <h3 class="font-semibold text-gray-900 mb-1">Create account</h3>
                            <p class="text-sm text-gray-500">Sign up in seconds, completely free</p>
                        </div>
                        <div class="text-center">
                            <div class="w-14 h-14 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md" style="background-color:#F3A712">2</div>
                            <h3 class="font-semibold text-gray-900 mb-1">List or browse</h3>
                            <p class="text-sm text-gray-500">Post items or find what you need</p>
                        </div>
                        <div class="text-center">
                            <div class="w-14 h-14 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md" style="background-color:#F3A712">3</div>
                            <h3 class="font-semibold text-gray-900 mb-1">Chat & deal</h3>
                            <p class="text-sm text-gray-500">Negotiate live, close instantly</p>
                        </div>
                    </div>
                </div>
                
                <!-- Testimonials -->
                <div class="mb-16">
                    <div class="text-center mb-8">
                        <div class="flex items-center justify-center gap-2 mb-2">
                            <svg class="w-6 h-6 text-[#F3A712]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                            </svg>
                            <h2 class="text-2xl font-bold text-gray-900">Trusted by the community</h2>
                        </div>
                        <p class="text-gray-500">What our users say about TradeHive</p>
                    </div>
                    <div class="grid md:grid-cols-3 gap-6">
                        <% const testimonials = [
                            { name: "Sarah Johnson", role: "Verified Seller", text: "The chat feature helped me sell my camera within hours. Direct communication makes all the difference.", rating: 5, avatar: "SJ" },
                            { name: "Michael Chen", role: "Collector", text: "Found rare vinyl records here that I've been searching for years. The platform is a hidden gem.", rating: 5, avatar: "MC" },
                            { name: "Amina Wanjiku", role: "Buyer", text: "Safe, reliable, and the sellers are responsive. My go-to marketplace in Kenya.", rating: 5, avatar: "AW" }
                        ]; %>
                        <% testimonials.forEach(t => { %>
                            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition">
                                <div class="flex items-center gap-0.5 mb-3">
                                    <% for(let i = 0; i < t.rating; i++) { %>
                                        <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                        </svg>
                                    <% } %>
                                </div>
                                <p class="text-gray-600 text-sm leading-relaxed mb-4">"<%= t.text %>"</p>
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full flex items-center justify-center text-white font-medium text-sm" style="background-color:#F3A712">
                                        <%= t.avatar %>
                                    </div>
                                    <div>
                                        <p class="font-medium text-gray-900 text-sm"><%= t.name %></p>
                                        <p class="text-xs text-gray-500"><%= t.role %></p>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
                
                <!-- CTA Banner -->
                <div class="rounded-2xl p-8 lg:p-10 text-center text-white" style="background: linear-gradient(to right, #F3A712, #F97316)">
                    <div class="flex justify-center mb-3">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 10 10c-2-1-4-1-6 0 1 1 2 2 4 3-1 1-2 2-3 4 2-1 4-2 6-3 1 1 2 2 4 3 0-2-1-4-2-6 2 0 4 1 5 2 0-2-1-4-2-6 1 1 2 2 3 4 0-2-1-4-2-6 1 1 2 2 3 4"></path>
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold mb-2">Ready to start selling?</h2>
                    <p class="text-white/90 mb-5">Join thousands of sellers making money on TradeHive</p>
                    <a href="/sell" class="bg-white font-semibold px-6 py-2.5 rounded-lg hover:shadow-lg transition-all inline-flex items-center gap-2 text-sm" style="color:#F3A712">
                        Start selling now
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </main>
        
        <!-- Include Footer Component -->
        <%- include('footer') %>
        
    </div>
    
    <script type="module">
        import '../components/BidNavbar.js';
        
        document.getElementById('current-year').textContent = new Date().getFullYear();
        
        // Listen for dark mode changes to update body class
        window.addEventListener('darkmode-changed', (e) => {
            if (e.detail.isDarkMode) {
                document.body.classList.add('dark-mode');
            } else {
                document.body.classList.remove('dark-mode');
            }
        });
        
        // Check initial dark mode
        const savedDarkMode = localStorage.getItem('bidnest_darkMode');
        if (savedDarkMode === 'true') {
            document.body.classList.add('dark-mode');
        }
    </script>
</body>
</html>