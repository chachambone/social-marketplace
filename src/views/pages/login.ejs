<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../components/head', { 
        title: title, 
        description: description 
    }) %>
</head>
<body class="min-h-screen">
    <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8 animate-fadeIn">
       
            
            <!-- Dynamic Component Container -->
            <%- include('dynamic-component-container', { 
                containerClass: 'animate-slideInRight',
                loadingText: ''
            }) %>
            
            <!-- Footer Links -->
            <div class="text-center text-white/70 text-xs space-x-4">
                <a href="/" class="hover:text-white transition-colors">Home</a>
                <span>•</span>
                <a href="/terms" class="hover:text-white transition-colors">Terms</a>
                <span>•</span>
                <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
                <span>•</span>
                <a href="/help" class="hover:text-white transition-colors">Help</a>
            </div>
        </div>
    </div>
    
    <!-- Component configuration -->
    <%- include('component-loader', { 
        components: [
            { 
                fileName: 'LoginForm.js', 
                componentName: 'LoginForm',
                customName: 'login-form',
                props: {
                    redirectUrl: '/'
                },
                events: {
                    'login-success': 'onLoginSuccess',
                    'register-success': 'onRegisterSuccess'
                }
            }
        ],
        basePath: '/',
        debug: false,
        autoLoad: true,
        containerClass: 'animate-slideInRight',
        loadingText: 'Loading authentication form...',
        customHandlers: {
            onLoginSuccess: (e) => {
                console.log('Custom login success handler', e);
            },
            onRegisterSuccess: (e) => {
                console.log('Custom register success handler', e);
            }
        }
    }) %>
</body>
</html>