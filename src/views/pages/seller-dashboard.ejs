<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../components/head', { 
        title: title, 
        description: description 
    }) %>
</head>

<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- Include Navbar -->
    <%- include('../components/navbar', { 
        user: user,
        currentPath: currentPath || '/browser'
    }) %>
    
    <!-- Main Content -->
    <div class="container mx-auto">
        <div class="animate-fadeIn">
        
            
          
        </div>
    </div>
    
    <!-- Component configuration -->
    <%- include('component-loader', { 
        components: [
            { 
                fileName: 'SellerDashboard.js', 
                componentName: 'SellerDashboard',
                customName: 'seller-dashboard',
                props: {},
                events: {
                    'item-clicked': 'onItemClicked',
                    'add-to-cart': 'onAddToCart'
                }
            }
        ],
        basePath: '/components/',
        debug: process.env.NODE_ENV === 'development',
        autoLoad: true,
        containerId: 'buyer-dashboard-container',
        containerClass: 'animate-slideInRight',
        loadingText: 'Loading items...',
        customHandlers: {
            onItemClicked: (e) => {
                console.log('Item clicked:', e.detail);
                window.location.href = `/items/${e.detail.id}`;
            },
            onAddToCart: (e) => {
                console.log('Add to cart:', e.detail);
                showToast('Item added to cart! 🛒', 'success');
            }
        }
    }) %>
    

    <script type="module">
        
        // Also store user data in localStorage for the component to access
        const userData = {
            id: '<%= user?.id %>',
            name: '<%= user?.name || user?.username %>',
            email: '<%= user?.email %>',
            userType: '<%= user?.userType %>'
        };
        
        if (userData.id && userData.id !== '') {
            localStorage.setItem('user', JSON.stringify(userData));
        }
        
        // Dispatch event that user is loaded
        window.dispatchEvent(new CustomEvent('user-loaded', { detail: userData }));
    </script>

    <script>
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-4 right-4 z-50 bg-white rounded-xl shadow-2xl p-4 flex items-center gap-3 animate-slideUp`;
            toast.innerHTML = `
                <div class="text-2xl">${type === 'success' ? '✅' : 'ℹ️'}</div>
                <div class="flex-1">
                    <p class="text-gray-900 font-medium">${message}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="text-gray-400 hover:text-gray-600">✕</button>
            `;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
        
        // Add slideUp animation if not present
        if (!document.querySelector('#animation-styles')) {
            const style = document.createElement('style');
            style.id = 'animation-styles';
            style.textContent = `
                @keyframes slideUp {
                    from { opacity: 0; transform: translateY(20px); }
                    to { opacity: 1; transform: translateY(0); }
                }
                .animate-slideUp {
                    animation: slideUp 0.3s ease-out;
                }
            `;
            document.head.appendChild(style);
        }
    </script>
</body>
</html>