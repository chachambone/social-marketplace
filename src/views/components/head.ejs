<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<meta name="description" content="<%= description %>">

<!-- Import map for Lit -->
<script type="importmap">
    {
        "imports": {
            "lit": "https://cdn.jsdelivr.net/npm/lit@3.2.1/index.js",
            "lit/": "https://cdn.jsdelivr.net/npm/lit@3.2.1/",
            "lit/decorators.js": "https://cdn.jsdelivr.net/npm/lit@3.2.1/decorators.js",
            "lit-html": "https://cdn.jsdelivr.net/npm/lit-html@3.2.0/lit-html.js",
            "lit-html/": "https://cdn.jsdelivr.net/npm/lit-html@3.2.0/",
            "lit-element/lit-element.js": "https://cdn.jsdelivr.net/npm/lit-element@4.1.0/lit-element.js",
            "@lit/reactive-element": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/reactive-element.js",
            "@lit/reactive-element/": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/",
            "lucide": "https://cdn.jsdelivr.net/npm/lucide@0.344.0/dist/umd/lucide.min.js"
        }
    }
</script>

<!-- Tailwind CSS CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Lucide Icons -->
<script src="https://unpkg.com/lucide@latest"></script>

<style>
    /* CSS Variables - Light Theme (Default) */
    :root {
        --primary: #F3A712;
        --surface-tint: #7E570F;
        --on-primary: #FFFFFF;
        --primary-container: #FFDDB1;
        --on-primary-container: #614000;
        --secondary: #6F5B40;
        --on-secondary: #FFFFFF;
        --secondary-container: #FADEBB;
        --on-secondary-container: #56442A;
        --tertiary: #506441;
        --on-tertiary: #FFFFFF;
        --tertiary-container: #D3EABD;
        --on-tertiary-container: #394C2B;
        --error: #BA1A1A;
        --on-error: #FFFFFF;
        --error-container: #FFDAD6;
        --on-error-container: #93000A;
        --background: #FFF8F3;
        --on-background: #201B13;
        --surface: #FFF8F3;
        --on-surface: #201B13;
        --surface-variant: #EFE0CF;
        --on-surface-variant: #4F4539;
        --outline: #817567;
        --outline-variant: #D3C4B4;
        --shadow: #000000;
        --scrim: #000000;
        --inverse-surface: #362F27;
        --inverse-on-surface: #FBEFE2;
        --inverse-primary: #F3BD6E;
        --primary-fixed: #FFDDB1;
        --on-primary-fixed: #291800;
        --primary-fixed-dim: #F3BD6E;
        --on-primary-fixed-variant: #614000;
        --secondary-fixed: #FADEBB;
        --on-secondary-fixed: #271904;
        --secondary-fixed-dim: #DCC3A1;
        --on-secondary-fixed-variant: #56442A;
        --tertiary-fixed: #D3EABD;
        --on-tertiary-fixed: #0F2004;
        --tertiary-fixed-dim: #B7CEA2;
        --on-tertiary-fixed-variant: #394C2B;
        --surface-dim: #E4D8CC;
        --surface-bright: #FFF8F3;
        --surface-container-lowest: #FFFFFF;
        --surface-container-low: #FEF2E5;
        --surface-container: #F8ECDF;
        --surface-container-high: #F3E6DA;
        --surface-container-highest: #EDE1D4;
    }

    /* Dark Theme */
    [data-theme="dark"] {
        --primary: #F3BD6E;
        --surface-tint: #F3BD6E;
        --on-primary: #442B00;
        --primary-container: #614000;
        --on-primary-container: #FFDDB1;
        --secondary: #DCC3A1;
        --on-secondary: #3D2E16;
        --secondary-container: #56442A;
        --on-secondary-container: #FADEBB;
        --tertiary: #B7CEA2;
        --on-tertiary: #233516;
        --tertiary-container: #394C2B;
        --on-tertiary-container: #D3EABD;
        --error: #FFB4AB;
        --on-error: #690005;
        --error-container: #93000A;
        --on-error-container: #FFDAD6;
        --background: #18130B;
        --on-background: #EDE1D4;
        --surface: #18130B;
        --on-surface: #EDE1D4;
        --surface-variant: #4F4539;
        --on-surface-variant: #D3C4B4;
        --outline: #9B8F80;
        --outline-variant: #4F4539;
        --shadow: #000000;
        --scrim: #000000;
        --inverse-surface: #EDE1D4;
        --inverse-on-surface: #362F27;
        --inverse-primary: #7E570F;
        --primary-fixed: #FFDDB1;
        --on-primary-fixed: #291800;
        --primary-fixed-dim: #F3BD6E;
        --on-primary-fixed-variant: #614000;
        --secondary-fixed: #FADEBB;
        --on-secondary-fixed: #271904;
        --secondary-fixed-dim: #DCC3A1;
        --on-secondary-fixed-variant: #56442A;
        --tertiary-fixed: #D3EABD;
        --on-tertiary-fixed: #0F2004;
        --tertiary-fixed-dim: #B7CEA2;
        --on-tertiary-fixed-variant: #394C2B;
        --surface-dim: #18130B;
        --surface-bright: #3F382F;
        --surface-container-lowest: #120D07;
        --surface-container-low: #201B13;
        --surface-container: #251F17;
        --surface-container-high: #2F2921;
        --surface-container-highest: #3A342B;
    }

    /* Apply theme variables to body */
    body {
        background-color: var(--background);
        color: var(--on-background);
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Animation keyframes */
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes slideInLeft {
        from { opacity: 0; transform: translateX(-20px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes slideInRight {
        from { opacity: 0; transform: translateX(20px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    @keyframes bounce {
        0%, 100% { transform: translateY(0) scale(1) rotate(0deg); }
        50% { transform: translateY(-10px) scale(1.1) rotate(12deg); }
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Animation classes */
    .animate-fadeIn {
        animation: fadeIn 0.5s ease-out;
    }

    .animate-slideInLeft {
        animation: slideInLeft 0.5s ease-out;
    }

    .animate-slideInRight {
        animation: slideInRight 0.5s ease-out;
    }

    .animate-spin {
        animation: spin 1s linear infinite;
    }

    .animate-bounce {
        animation: bounce 0.5s ease-in-out;
    }

    .animate-slideUp {
        animation: slideUp 0.3s ease-out;
    }

    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    /* Utility classes */
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Hover effects */
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    /* Hide scrollbar but keep functionality */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }

    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: var(--surface-variant);
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
        background: var(--primary);
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: var(--primary-container);
    }

    /* Selection color */
    ::selection {
        background-color: var(--primary);
        color: var(--on-primary);
    }

    /* Focus outline */
    :focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
    }

    /* Smooth transitions for theme switching */
    * {
        transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
</style>

<!-- Theme initialization script -->
<script>
    // Initialize theme based on localStorage
    (function() {
        const savedTheme = localStorage.getItem('bidnest_theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('bidnest_theme', 'dark');
        } else {
            document.documentElement.setAttribute('data-theme', 'light');
            localStorage.setItem('bidnest_theme', 'light');
        }
        
        // Apply theme to body class for Tailwind dark mode compatibility
        if (document.documentElement.getAttribute('data-theme') === 'dark') {
            document.body.classList.add('dark-mode');
        } else {
            document.body.classList.remove('dark-mode');
        }
    })();

    // Theme toggle function (available globally)
    window.toggleTheme = function() {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('bidnest_theme', newTheme);
        
        // Update body class for Tailwind
        if (newTheme === 'dark') {
            document.body.classList.add('dark-mode');
        } else {
            document.body.classList.remove('dark-mode');
        }
        
        // Dispatch event for components to listen to
        window.dispatchEvent(new CustomEvent('theme-changed', { 
            detail: { isDarkMode: newTheme === 'dark' }
        }));
        
        console.log(`Theme changed to: ${newTheme}`);
    };

    // Get current theme
    window.getCurrentTheme = function() {
        return document.documentElement.getAttribute('data-theme') || 'light';
    };

    // Check if dark mode is active
    window.isDarkMode = function() {
        return document.documentElement.getAttribute('data-theme') === 'dark';
    };
</script>