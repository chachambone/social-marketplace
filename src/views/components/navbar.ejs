<nav class="fixed top-0 w-full z-50 transition-all duration-300 shadow-md" style="background-color: #F3A712;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo Section -->
      <div class="flex items-center gap-2">
        <a href="/" class="flex items-center gap-2">
          <img 
            src="/images/logo.jpg" 
            alt="BidHive Logo" 
            class="h-8 w-auto object-contain cursor-pointer transition-all duration-300 hover:scale-110 hover:rotate-6"
          />
          <span class="font-black text-2xl tracking-tight hover:opacity-90 transition text-white">
            Bid<span class="text-gray-900">Hive</span>
          </span>
        </a>
      </div>

      <!-- Desktop Navigation - Conditional based on user type -->
      <div class="hidden md:flex items-center gap-1 bg-white/20 backdrop-blur-sm rounded-full px-2 py-1">
        <% if (user) { 
          // Navigation items for logged in users
          let navItems = [];
          
          if (user.userType === 'seller') {
            navItems.push(
              { path: "/seller/dashboard", label: "Dashboard", icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" }
            );
          } else if (user.userType === 'buyer') {
            navItems.push(
              { path: "/browse", label: "Browse", icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" }
            );
          }
          
          navItems.forEach(item => { %>
            <a href="<%= item.path %>"
              class="px-4 py-2 rounded-full transition-all duration-300 flex items-center gap-2 text-sm font-medium <%= currentPath === item.path ? 'bg-white text-[#F3A712] shadow-lg scale-105' : 'text-white hover:bg-white/20' %>">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"></path>
              </svg>
              <%= item.label %>
            </a>
          <% });
        } else { 
          // Guest Banner - Shown when not logged in
        %>
          <div class="flex items-center gap-3 px-4 py-1">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
              <span class="text-white/90 text-sm font-medium">Guest Mode</span>
            </div>
            <div class="w-px h-4 bg-white/30"></div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M6 5h12M6 19h12M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"></path>
              </svg>
              <span class="text-white/80 text-xs">Browse as guest</span>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Right Section -->
      <div class="flex items-center gap-2">
        <!-- Dark Mode Toggle -->
        <button id="darkModeToggle"
          class="p-2 rounded-full hover:bg-white/20 transition text-white" 
          aria-label="Toggle dark mode">
          <svg id="darkModeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>

        <!-- NOT LOGGED IN -->
        <% if (!user) { %>
          <div class="flex gap-2">
            <a href="/login"
              class="text-sm font-semibold text-[#F3A712] bg-white px-4 py-2 rounded-full hover:bg-white/90 transition hidden sm:block">
              Sign In/Register
            </a>
          
          </div>
        
        <% } else { %>
          <!-- LOGGED IN: Notifications -->
          <div class="relative notifications-menu">
            <button id="notificationsBtn"
              class="relative p-2 rounded-full hover:bg-white/20 transition text-white" aria-label="Notifications">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
              </svg>
              <span id="unreadBadge" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center animate-pulse"></span>
            </button>
          </div>

          <!-- LOGGED IN: User Menu -->
          <div class="relative user-menu">
            <button id="userMenuBtn"
              class="flex items-center gap-2 bg-white/20 hover:bg-white/30 px-3 py-2 rounded-full transition group text-white"
              aria-label="User menu">
              <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-[#F3A712] text-sm font-bold shadow-md group-hover:scale-110 transition">
                <%= user.username ? user.username.charAt(0).toUpperCase() : (user.email ? user.email.charAt(0).toUpperCase() : 'U') %>
              </div>
              <span class="text-sm font-medium hidden sm:inline"><%= user.username || user.email.split('@')[0] %></span>
              <svg class="w-4 h-4 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="userMenuDropdown" class="hidden absolute right-0 mt-3 w-72 bg-white rounded-2xl shadow-2xl overflow-hidden z-50 animate-slideDown">
              <div class="p-4" style="background-color: #FEF3C7;">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-md" style="background-color:#F3A712">
                    <%= user.username ? user.username.charAt(0).toUpperCase() : (user.email ? user.email.charAt(0).toUpperCase() : 'U') %>
                  </div>
                  <div class="flex-1">
                    <p class="font-bold text-gray-900"><%= user.username || user.email %></p>
                    <p class="text-xs text-gray-600"><%= user.email %></p>
                    <span class="text-xs capitalize px-2 py-0.5 rounded-full font-medium <%= user.userType === 'seller' ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %>">
                      <%= user.userType || 'buyer' %>
                    </span>
                  </div>
                </div>
              </div>
              <div class="py-2">
                <a href="/profile" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition group">
                  <svg class="w-5 h-5 text-gray-500 group-hover:text-[#F3A712]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <span class="text-sm text-gray-700">My Profile</span>
                </a>
                
                <div class="border-t my-1"></div>
                <a href="/logout" class="flex items-center gap-3 px-4 py-3 hover:bg-red-50 transition group">
                  <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                  </svg>
                  <span class="text-sm text-red-600">Logout</span>
                </a>
              </div>
            </div>
          </div>
        <% } %>

        <!-- Mobile menu button -->
        <div class="md:hidden">
          <button id="mobileMenuBtn" class="p-2 rounded-lg hover:bg-white/20 transition text-white" aria-label="Toggle menu">
            <svg id="mobileMenuIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobileMenu" class="hidden md:hidden py-4 border-t border-white/20 animate-slideDown" style="background-color: #F3A712;">
    <div class="flex flex-col gap-2 px-4">
      <% if (user) { 
        let mobileNavItems = [];
        
        if (user.userType === 'seller') {
          mobileNavItems.push(
            { path: "/seller/dashboard", label: "Dashboard", icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" }
          );
        } else if (user.userType === 'buyer') {
          mobileNavItems.push(
            { path: "/browse", label: "Browse", icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" }
          );
        }
        
        mobileNavItems.forEach(item => { %>
          <a href="<%= item.path %>"
            class="px-4 py-3 rounded-xl transition flex items-center gap-3 text-white hover:bg-white/10">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"></path>
            </svg>
            <%= item.label %>
          </a>
        <% });
      } else { %>
        <!-- Guest Mode in Mobile Menu -->
        <div class="px-4 py-3 text-center">
          <div class="bg-white/10 rounded-xl p-4 mb-2">
            <svg class="w-12 h-12 mx-auto text-white/60 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            <p class="text-white font-medium">Guest Mode</p>
            <p class="text-white/70 text-xs mt-1">Sign in to access more features</p>
          </div>
        </div>
      <% } %>
      
      <div class="border-t border-white/20 my-2"></div>
      
      <% if (!user) { %>
        <a href="/login" class="px-4 py-3 rounded-xl bg-white text-[#F3A712] font-semibold text-center">Sign In</a>
        <a href="/register" class="px-4 py-3 rounded-xl bg-white/20 text-white font-semibold text-center">Register</a>
      <% } else { %>
        <a href="/profile" class="px-4 py-3 rounded-xl hover:bg-white/10 transition flex items-center gap-3 text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          My Profile
        </a>
        <% if (user.userType === 'seller') { %>
        <a href="/my-listings" class="px-4 py-3 rounded-xl hover:bg-white/10 transition flex items-center gap-3 text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
          </svg>
          My Listings
        </a>
        <% } %>
        <a href="/logout" class="px-4 py-3 text-left rounded-xl hover:bg-white/10 transition flex items-center gap-3 text-red-100">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          Logout
        </a>
      <% } %>
    </div>
  </div>
</nav>

<div class="h-16"></div>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  
  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
  
  // User menu dropdown
  const userMenuBtn = document.getElementById('userMenuBtn');
  const userMenuDropdown = document.getElementById('userMenuDropdown');
  
  if (userMenuBtn && userMenuDropdown) {
    userMenuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      userMenuDropdown.classList.toggle('hidden');
    });
    
    document.addEventListener('click', (e) => {
      if (userMenuBtn && userMenuDropdown && !userMenuBtn.contains(e.target) && !userMenuDropdown.contains(e.target)) {
        userMenuDropdown.classList.add('hidden');
      }
    });
  }
  
  // Dark mode toggle
  const darkModeToggle = document.getElementById('darkModeToggle');
  const darkModeIcon = document.getElementById('darkModeIcon');
  
  if (darkModeToggle && darkModeIcon) {
    const isDarkMode = localStorage.getItem('bidhive_darkMode') === 'true';
    if (isDarkMode) {
      document.documentElement.classList.add('dark');
      document.body.classList.add('dark-mode');
      darkModeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
    }
    
    darkModeToggle.addEventListener('click', () => {
      const isDark = document.body.classList.toggle('dark-mode');
      document.documentElement.classList.toggle('dark', isDark);
      localStorage.setItem('bidhive_darkMode', isDark);
      
      if (isDark) {
        darkModeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
      } else {
        darkModeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
      }
    });
  }
</script>

<style>
  /* Animation for dropdown */
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-slideDown {
    animation: slideDown 0.3s ease-out;
  }
  
  /* Dark mode styles */
  .dark-mode {
    background-color: #1a1a2e;
    color: #eee;
  }
  
  .dark-mode .bg-white {
    background-color: #16213e !important;
  }
  
  .dark-mode .text-gray-900 {
    color: #eee !important;
  }
</style>