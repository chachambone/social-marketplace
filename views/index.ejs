<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    
    <!-- Import Map for Lit CDN - This is critical! -->
    <script type="importmap">
        {
            "imports": {
                "lit": "https://cdn.jsdelivr.net/npm/lit@3.2.1/index.js",
                "lit/": "https://cdn.jsdelivr.net/npm/lit@3.2.1/",
                "@lit/reactive-element": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/reactive-element.js",
                "@lit/reactive-element/": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/",
                "lit-element/lit-element.js": "https://cdn.jsdelivr.net/npm/lit-element@4.1.0/lit-element.js",
                "lit-html": "https://cdn.jsdelivr.net/npm/lit-html@3.2.0/lit-html.js",
                "lit-html/": "https://cdn.jsdelivr.net/npm/lit-html@3.2.0/"
            }
        }
    </script>
    
    <!-- OUR compiled Tailwind CSS (via PostCSS) -->
    <link rel="stylesheet" href="/css/main.css">
    
    <!-- Fallback styles for no JavaScript -->
    <noscript>
        <style>
            .no-js-warning {
                padding: 1rem;
                background: #fee2e2;
                color: #dc2626;
                text-align: center;
                font-family: sans-serif;
            }
        </style>
    </noscript>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- Rest of your body remains the same -->
    <div id="app" class="flex flex-col min-h-screen">
        <header class="bg-white shadow-md sticky top-0 z-50">
            <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
                <div class="flex justify-between items-center">
                    <div class="flex items-center space-x-2">
                        <span class="text-3xl">🃏</span>
                        <h1 class="text-xl sm:text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                            Collectible Trading Post
                        </h1>
                    </div>
                    <div id="user-status" class="flex items-center space-x-4"></div>
                </div>
            </nav>
        </header>

        <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div id="loading-indicator" class="text-center py-12">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                <p class="mt-2 text-gray-600">Loading marketplace...</p>
            </div>
            <marketplace-app></marketplace-app>
        </main>

        <footer class="bg-white border-t border-gray-200 mt-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <p class="text-center text-gray-500 text-sm">
                    © 2026 Collectible Trading Post. Buy, sell, and negotiate with confidence.
                </p>
            </div>
        </footer>
    </div>

    <!-- Load compiled TypeScript components -->
    <script type="module" src="/dist/app.js"></script>
    
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const observer = new MutationObserver((mutations) => {
                const app = document.querySelector('marketplace-app');
                if (app && app.shadowRoot) {
                    const loadingIndicator = document.getElementById('loading-indicator');
                    if (loadingIndicator) {
                        loadingIndicator.style.display = 'none';
                    }
                    observer.disconnect();
                }
            });
            observer.observe(document.body, { childList: true, subtree: true });
            
            setTimeout(() => {
                const loadingIndicator = document.getElementById('loading-indicator');
                if (loadingIndicator && loadingIndicator.style.display !== 'none') {
                    loadingIndicator.style.display = 'none';
                }
            }, 3000);
        });
    </script>
</body>
</html>