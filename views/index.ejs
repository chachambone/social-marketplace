<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    
    <!-- Preconnect for faster CDN loading -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    
    <!-- Lit Element (ES modules) -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/lit@3.2.1/index.js"></script>
    
    <!-- OUR compiled Tailwind CSS (via PostCSS) - Production optimized -->
    <link rel="stylesheet" href="/css/main.css">
    
    <!-- Fallback styles for no JavaScript -->
    <noscript>
        <style>
            .no-js-warning {
                padding: 1rem;
                background: #fee2e2;
                color: #dc2626;
                text-align: center;
                font-family: sans-serif;
            }
        </style>
    </noscript>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- No JavaScript fallback -->
    <noscript>
        <div class="no-js-warning">
            ⚠️ JavaScript is required for this application to function properly.
        </div>
    </noscript>

    <!-- Main App Container -->
    <div id="app" class="flex flex-col min-h-screen">
        <!-- Server-side rendered shell with improved design -->
        <header class="bg-white shadow-md sticky top-0 z-50">
            <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
                <div class="flex justify-between items-center">
                    <div class="flex items-center space-x-2">
                        <span class="text-3xl">🃏</span>
                        <h1 class="text-xl sm:text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                            Collectible Trading Post
                        </h1>
                    </div>
                    <div id="user-status" class="flex items-center space-x-4">
                        <!-- Dynamically populated by Lit -->
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <!-- Loading indicator -->
            <div id="loading-indicator" class="text-center py-12">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                <p class="mt-2 text-gray-600">Loading marketplace...</p>
            </div>
            
            <!-- Dynamic content will be rendered by Lit components -->
            <marketplace-app></marketplace-app>
        </main>

        <!-- Footer -->
        <footer class="bg-white border-t border-gray-200 mt-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <p class="text-center text-gray-500 text-sm">
                    © 2026 Collectible Trading Post. Buy, sell, and negotiate with confidence.
                </p>
            </div>
        </footer>
    </div>

    <!-- Load compiled TypeScript components -->
    <script type="module" src="/dist/app.js"></script>
    
    <!-- Hide loading indicator after components load -->
    <script>
        // Simple script to hide loading indicator when marketplace-app is ready
        window.addEventListener('DOMContentLoaded', () => {
            const observer = new MutationObserver((mutations) => {
                const app = document.querySelector('marketplace-app');
                if (app && app.shadowRoot) {
                    const loadingIndicator = document.getElementById('loading-indicator');
                    if (loadingIndicator) {
                        loadingIndicator.style.display = 'none';
                    }
                    observer.disconnect();
                }
            });
            observer.observe(document.body, { childList: true, subtree: true });
            
            // Timeout fallback - hide after 3 seconds even if component not ready
            setTimeout(() => {
                const loadingIndicator = document.getElementById('loading-indicator');
                if (loadingIndicator && loadingIndicator.style.display !== 'none') {
                    loadingIndicator.style.display = 'none';
                }
            }, 3000);
        });
    </script>
</body>
</html>