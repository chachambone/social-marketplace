{
  "devDependencies": {
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ejs": "^5.0.2",
    "lit": "^3.3.2"
  },
  "scripts": {
  "dev": "concurrently \"npm run watch:css\" \"npm run watch:ts\" \"nodemon server/index.js\"",
  "watch:ts": "tsc --watch",
  "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/main.css --watch",
  "build:ts": "tsc",
  "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/main.css --minify",
  "build": "npm run build:ts && npm run build:css",
  "setup": "npm install && npm run build"
}
}
