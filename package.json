{
  "name": "social-marketplace",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:ts:client": "tsc -p tsconfig.client.json",
    "build:ts:server": "tsc -p tsconfig.server.json",
    "build:css": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/output.css --minify",
    "generate:css": "node --experimental-specifier-resolution=node src/scripts/generate-css-ts.ts",
    "build": "npm run build:css && npm run generate:css && npm run build:ts:client && npm run build:ts:server",
    "watch:ts:client": "tsc -p tsconfig.client.json --watch",
    "watch:ts:server": "tsc -p tsconfig.server.json --watch",
    "watch:css": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/output.css --watch",
    "dev": "concurrently \"npm run watch:ts:client\" \"npm run watch:ts:server\" \"npm run watch:css\" \"node --experimental-specifier-resolution=node dist/server.js\"",
    "start": "node --experimental-specifier-resolution=node dist/server.js",
    "render-start": "node --experimental-specifier-resolution=node dist/server.js"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/postcss": "^4.2.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lit": "^3.3.2",
    "nodemailer": "^8.0.5",
    "react-redux": "^9.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/tailwindcss": "^3.0.11",
    "@types/trusted-types": "^2.0.7",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2"
  }
}