{
  "name": "social-marketplace",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:ts:client": "tsc -p tsconfig.client.json",
    "build:ts:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:ts:client && npm run build:ts:server",
    "watch:ts:client": "tsc -p tsconfig.client.json --watch",
    "watch:ts:server": "tsc -p tsconfig.server.json --watch",
    "dev": "node --experimental-specifier-resolution=node dist/server.js",
    "start": "node --experimental-specifier-resolution=node dist/server.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "lit": "^3.3.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/tailwindcss": "^3.0.11",
    "@types/trusted-types": "^2.0.7",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2"
  }
}
